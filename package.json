    "@react-router/dev": "^7.13.2",
    "@react-router/node": "^7.13.2",
    "@tailwindcss/typography": "^0.5.16",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "idb-keyval": "^6.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260331.1",
