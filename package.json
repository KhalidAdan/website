{
  "name": "khld-md",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "typegen": "wrangler types",
