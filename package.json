{
  "name": "khld-md",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --persist-to .wrangler/d1-temp",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config tests/e2e/playwright.config.ts --ui"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.30.3",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-prism": "^7.20.0",
    "@milkdown/preset-commonmark": "^7.20.0",
    "@milkdown/preset-gfm": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@react-router/cloudflare": "^7.13.2",
    "@react-router/dev": "^7.13.2",
    "@react-router/node": "^7.13.2",
    "@tailwindcss/typography": "^0.5.16",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "lazy-tree-view": "^1.0.2",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260331.1",
    "@playwright/test": "^1.59.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.79.0"
  }
}
